# =============================================================================
# vkQuake Server - Environment Configuration
#
# Copy this file to .env and edit your settings:
#   cp .env.example .env
#
# Never commit your .env file — it contains sensitive settings.
# =============================================================================


# -----------------------------------------------------------------------------
# Host settings
# Get your user ID and group ID with: id
# -----------------------------------------------------------------------------
PUID=1000
PGID=1000

# Path where container data is stored on the host
# Example: CONTAINER_DIR=/srv/docker/containers
CONTAINER_DIR=/path/to/your/containers


# -----------------------------------------------------------------------------
# Server identity
# -----------------------------------------------------------------------------
QUAKE_SERVER_NAME=My vkQuake Server
QUAKE_MAX_PLAYERS=16
QUAKE_PORT=26000


# -----------------------------------------------------------------------------
# Game mode
# Only one of DEATHMATCH/COOP should be 1 at a time
# TEAMPLAY: 0=off  1=no friendly fire  2=friendly fire
# -----------------------------------------------------------------------------
QUAKE_DEATHMATCH=1
QUAKE_COOP=0
QUAKE_TEAMPLAY=0


# -----------------------------------------------------------------------------
# Skill: standard Quake scale 0-3
# 0=Easy  1=Normal  2=Hard  3=Nightmare
# Only affects monsters in coop mode — ignored by Frogbot bots
# -----------------------------------------------------------------------------
QUAKE_SKILL=1


# -----------------------------------------------------------------------------
# Match settings
# -----------------------------------------------------------------------------
QUAKE_FRAGLIMIT=20
QUAKE_TIMELIMIT=10


# -----------------------------------------------------------------------------
# Map settings
# QUAKE_MAP: starting map when server loads
# QUAKE_MAP_ROTATION: comma-separated list of maps to cycle through
# QUAKE_ROTATION_MODE: 1=enable rotation  0=stay on same map
# -----------------------------------------------------------------------------
QUAKE_MAP=start
QUAKE_MAP_ROTATION=start,e1m1,e1m2,e1m3,e1m4,e1m5,e1m6,e1m7,e1m8
QUAKE_ROTATION_MODE=1


# -----------------------------------------------------------------------------
# Bots (Frogbot v2 — built into the image)
# QUAKE_ENABLE_BOTS: 1=load Frogbot mod  0=vanilla server (no bots)
# QUAKE_BOT_SKILL: Frogbot scale 0-20
#   0=Easiest  5=Default  10=Challenging  15=Hard  20=Inhuman
#
# Note: Bots must be added manually after connecting to the server.
#   In-game console: addbot
#   Via RCON:        rcon addbot
# -----------------------------------------------------------------------------
QUAKE_ENABLE_BOTS=1
QUAKE_BOT_SKILL=5


# -----------------------------------------------------------------------------
# Mod support
# Leave empty to use Frogbot when QUAKE_ENABLE_BOTS=1
# Set to a mod directory name to load a different mod instead
# Example: QUAKE_MOD=ctf
# -----------------------------------------------------------------------------
QUAKE_MOD=


# -----------------------------------------------------------------------------
# Admin / RCON
# Leave empty to disable RCON access
# To use: connect to server, then:
#   rcon_password yourpassword
#   rcon status
#   rcon addbot
#   rcon changelevel e1m1
# -----------------------------------------------------------------------------
QUAKE_ADMIN_PASSWORD=


# -----------------------------------------------------------------------------
# Server physics
# Standard Quake defaults — change only if you know why
# QUAKE_GRAVITY:   800=normal  200=low gravity  1200=heavy
# QUAKE_MAX_SPEED: 320=normal  400=fast
# QUAKE_FRICTION:  4=normal  2=slippery  8=sticky
# QUAKE_AIM:       1=auto-aim on  0=off (recommended for deathmatch)
# QUAKE_PAUSABLE:  0=server cannot be paused  1=can be paused
# -----------------------------------------------------------------------------
QUAKE_GRAVITY=800
QUAKE_MAX_SPEED=320
QUAKE_FRICTION=4
QUAKE_AIM=1
QUAKE_PAUSABLE=0


# -----------------------------------------------------------------------------
# Memory
# Amount of RAM in MB to allocate to the server
# 64MB is fine for most setups — increase for large mods
# -----------------------------------------------------------------------------
QUAKE_MEMORY=64


# -----------------------------------------------------------------------------
# Debug
# 1=write console output to /quake/logs/qconsole.log
# -----------------------------------------------------------------------------
QUAKE_CONDEBUG=1
