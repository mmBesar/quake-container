# =============================================================================
# quake-container .gitignore
# =============================================================================

# Local environment — contains sensitive settings like QUAKE_ADMIN_PASSWORD
# Copy .env.example to .env and edit your settings
.env

# Docker compose override files
docker-compose.override.yml

# Server runtime files — generated at container runtime, not needed in repo
quake/config/
quake/logs/

# Game files — these are copyrighted and must not be committed
quake/game/

# macOS
.DS_Store

# Editor temp files
*.swp
*.swo
*~
.vscode/
.idea/
